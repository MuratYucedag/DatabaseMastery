
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<!DOCTYPE html>
<html lang="tr">

    @await Component.InvokeAsync("_DashboardHeadComponentPartial")
   


<body>
    <div class="dashboard-wrap">

        @await Component.InvokeAsync("_DashboardHeaderComponentPartial")

        @await Component.InvokeAsync("_DashboardStatisticsCardsComponentPartial")
      
        @await Component.InvokeAsync("_DashboardLastReservationsComponentPartial")
       
        @await Component.InvokeAsync("_ChartComponentPartial")
     

        <!-- ══════════════════════════════════════════
             5. HIZLI İŞLEMLER  +  6. SON DEĞERLENDİRMELER
        ══════════════════════════════════════════ -->
        <div class="row g-3">

            <!-- HIZLI İŞLEMLER -->
            <div class="col-xl-4 col-md-6">
                <div class="dash-card h-100">
                    <div class="dash-card-header">
                        <div>
                            <div class="section-title">Hızlı İşlemler</div>
                            <div class="section-sub">Sık kullanılan kısayollar</div>
                        </div>
                    </div>
                    <div class="dash-card-body">
                        <div class="qa-grid">
                            <a href="/Reservation/CreateReservation" class="qa-btn qa-orange">
                                <div class="qa-icon" style="background:var(--accent-soft);">
                                    <i class="bi bi-calendar2-plus-fill" style="color:var(--accent-dark);"></i>
                                </div>
                                <span>Yeni Rezervasyon</span>
                            </a>
                            <a href="/Product/CreateProduct" class="qa-btn qa-green">
                                <div class="qa-icon" style="background:var(--green-soft);">
                                    <i class="bi bi-plus-circle-fill" style="color:var(--green);"></i>
                                </div>
                                <span>Ürün Ekle</span>
                            </a>
                            <a href="/Category/CreateCategory" class="qa-btn qa-blue">
                                <div class="qa-icon" style="background:var(--blue-soft);">
                                    <i class="bi bi-tags-fill" style="color:var(--blue);"></i>
                                </div>
                                <span>Kategori Ekle</span>
                            </a>
                            <a href="/Campaign/CreateCampaign" class="qa-btn qa-purple">
                                <div class="qa-icon" style="background:var(--purple-soft);">
                                    <i class="bi bi-megaphone-fill" style="color:var(--purple);"></i>
                                </div>
                                <span>Kampanya Oluştur</span>
                            </a>
                        </div>

                        <!-- Mini istatistik bölmesi -->
                        <div class="mt-3 p-3 rounded-3" style="background:linear-gradient(135deg,#1a1a1a,#2d2a26);">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span style="font-size:12px;color:rgba(255,255,255,0.5);font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Bugünkü Doluluk</span>
                                <span style="font-size:13px;font-weight:800;color:var(--accent);">%74</span>
                            </div>
                            <div style="background:rgba(255,255,255,0.08);border-radius:6px;height:6px;overflow:hidden;">
                                <div style="width:74%;height:100%;background:linear-gradient(90deg,var(--accent),var(--accent-dark));border-radius:6px;"></div>
                            </div>
                            <div class="d-flex justify-content-between mt-2" style="font-size:11px;color:rgba(255,255,255,0.35);">
                                <span>7 / 10 masa dolu</span>
                                <span>3 masa müsait</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SON DEĞERLENDİRMELER -->
            <div class="col-xl-4 col-md-6">
                <div class="dash-card h-100">
                    <div class="dash-card-header">
                        <div>
                            <div class="section-title">Son Değerlendirmeler</div>
                            <div class="section-sub">Müşteri yorumları</div>
                        </div>
                        <a href="#" class="view-all">Tümü <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="dash-card-body pt-0">

                        <div class="review-item">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="review-avatar" style="background:var(--accent-dark);">AY</div>
                                <div>
                                    <div class="review-name">Ahmet Yılmaz</div>
                                    <div class="review-date">2 saat önce</div>
                                </div>
                                <div class="ms-auto review-stars">★★★★★</div>
                            </div>
                            <div class="review-text">"Harika bir akşam yemeği deneyimi! Servis çok hızlı ve yemekler nefisti."</div>
                        </div>

                        <div class="review-item">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="review-avatar" style="background:var(--purple);">SK</div>
                                <div>
                                    <div class="review-name">Selin Kaya</div>
                                    <div class="review-date">5 saat önce</div>
                                </div>
                                <div class="ms-auto review-stars">★★★★<span style="color:#ddd;">★</span></div>
                            </div>
                            <div class="review-text">"Atmosfer çok güzeldi, tekrar geleceğiz. Sadece bekleyiş biraz uzundu."</div>
                        </div>

                        <div class="review-item">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="review-avatar" style="background:var(--teal);">MD</div>
                                <div>
                                    <div class="review-name">Murat Demir</div>
                                    <div class="review-date">Dün</div>
                                </div>
                                <div class="ms-auto review-stars">★★★★★</div>
                            </div>
                            <div class="review-text">"Vejetaryen menü seçenekleri gerçekten düşünülmüş, çok memnun kaldım."</div>
                        </div>

                        <div class="review-item">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="review-avatar" style="background:var(--blue);">EÇ</div>
                                <div>
                                    <div class="review-name">Emre Çelik</div>
                                    <div class="review-date">2 gün önce</div>
                                </div>
                                <div class="ms-auto review-stars">★★★<span style="color:#ddd;">★★</span></div>
                            </div>
                            <div class="review-text">"Yemekler iyiydi ama pencere kenarı isteğimiz karşılanamadı. Yine de güzeldi."</div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ÖZET + TAKVİM -->
            <div class="col-xl-4">
                <div class="dash-card h-100">
                    <div class="dash-card-header">
                        <div>
                            <div class="section-title">Haftalık Özet</div>
                            <div class="section-sub">Bu haftaki performans</div>
                        </div>
                    </div>
                    <div class="dash-card-body">

                        <div class="d-flex flex-column gap-3">

                            <div>
                                <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                                    <span style="font-weight:600;">Onay Oranı</span>
                                    <span style="font-weight:700;color:#16a34a;">%88</span>
                                </div>
                                <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                                    <div style="width:88%;height:100%;background:linear-gradient(90deg,var(--green),#16a34a);border-radius:6px;"></div>
                                </div>
                            </div>

                            <div>
                                <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                                    <span style="font-weight:600;">Masa Doluluk</span>
                                    <span style="font-weight:700;color:var(--accent-dark);">%74</span>
                                </div>
                                <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                                    <div style="width:74%;height:100%;background:linear-gradient(90deg,var(--accent),var(--accent-dark));border-radius:6px;"></div>
                                </div>
                            </div>

                            <div>
                                <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                                    <span style="font-weight:600;">Müşteri Memnuniyeti</span>
                                    <span style="font-weight:700;color:var(--blue);">%92</span>
                                </div>
                                <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                                    <div style="width:92%;height:100%;background:linear-gradient(90deg,var(--blue),#2563eb);border-radius:6px;"></div>
                                </div>
                            </div>

                            <div>
                                <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                                    <span style="font-weight:600;">İptal Oranı</span>
                                    <span style="font-weight:700;color:var(--red);">%8</span>
                                </div>
                                <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                                    <div style="width:8%;height:100%;background:linear-gradient(90deg,var(--red),#dc2626);border-radius:6px;"></div>
                                </div>
                            </div>

                        </div>

                        <hr style="border-color:var(--border);margin:18px 0;">

                        <!-- Gelir özeti -->
                        <div style="background:linear-gradient(135deg,var(--accent-soft),rgba(230,160,60,0.05));border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;">
                            <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;font-weight:700;margin-bottom:8px;">
                                <i class="bi bi-graph-up-arrow" style="color:var(--accent);"></i> Bu Haftanın Cirosu
                            </div>
                            <div style="font-family:'Playfair Display',serif;font-size:28px;font-weight:800;color:var(--text);line-height:1;">
                                ₺ 28.450
                            </div>
                            <div style="font-size:12px;color:var(--muted);margin-top:4px;">
                                Geçen haftaya göre <strong style="color:#16a34a;">+₺3.120</strong> artış
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
        <!-- /row -->

    </div><!-- /dashboard-wrap -->
    @await Component.InvokeAsync("_DashboardScriptsComponentPartial")

  
</body>
</html>

