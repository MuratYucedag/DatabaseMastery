    <script>
        /* ── Canlı Tarih ── */
        (function(){
          const tr = ['Pazar','Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi'];
          const mo = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
          const d = new Date();
          document.getElementById('liveDate').textContent =
            tr[d.getDay()] + ', ' + d.getDate() + ' ' + mo[d.getMonth()] + ' ' + d.getFullYear();
        })();

        /* ── Ortak Chart Defaults ── */
        Chart.defaults.font.family = "'DM Sans', sans-serif";
        Chart.defaults.font.size   = 12;
        Chart.defaults.color       = '#9a9590';

        /* ── 1. Çizgi Grafik (Günlük Rezervasyon) ── */
        new Chart(document.getElementById('lineChart'), {
          type: 'line',
          data: {
            labels: ['26 Şub','27 Şub','28 Şub','01 Mar','02 Mar','03 Mar','04 Mar'],
            datasets: [{
              label: 'Rezervasyon',
              data: [5, 8, 6, 11, 9, 14, 7],
              borderColor: '#e6a03c',
              backgroundColor: 'rgba(230,160,60,0.08)',
              borderWidth: 2.5,
              pointBackgroundColor: '#e6a03c',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              pointRadius: 5,
              tension: 0.4,
              fill: true,
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { color: '#f5f2ee' }, border: { display: false } },
              y: { grid: { color: '#f5f2ee' }, border: { display: false }, ticks: { stepSize: 3 }, beginAtZero: true }
            }
          }
        });

        /* ── 2. Bar Grafik (Kategori Sipariş) ── */
        new Chart(document.getElementById('barChart'), {
          type: 'bar',
          data: {
            labels: ['Başlangıçlar','Ana Yemekler','Tatlılar','İçecekler','Çorbalar'],
            datasets: [{
              label: 'Sipariş',
              data: [42, 118, 67, 93, 38],
              backgroundColor: ['rgba(139,92,246,0.7)','rgba(230,160,60,0.8)','rgba(34,197,94,0.7)','rgba(59,130,246,0.7)','rgba(20,184,166,0.7)'],
              borderRadius: 7,
              borderSkipped: false,
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { display: false }, border: { display: false } },
              y: { grid: { color: '#f5f2ee' }, border: { display: false }, beginAtZero: true }
            }
          }
        });

        /* ── 3. Pasta Grafik (Gelir Dağılımı) ── */
        new Chart(document.getElementById('pieChart'), {
          type: 'doughnut',
          data: {
            labels: ['Ana Yemekler','İçecekler','Tatlılar','Başlangıçlar'],
            datasets: [{
              data: [45, 25, 18, 12],
              backgroundColor: ['#e6a03c','#3b82f6','#22c55e','#8b5cf6'],
              borderWidth: 0,
              hoverOffset: 6,
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            cutout: '68%',
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: { label: ctx => ' ' + ctx.parsed + '%' }
              }
            }
          }
        });
    </script>
