<!-- ══════════════════════════════════════════
           4. GRAFİKLER
      ══════════════════════════════════════════ -->
<div class="row g-3 mb-4">

    <!-- Günlük Rezervasyon (Çizgi) -->


        @await Component.InvokeAsync("_DashboardLineChartComponentPartial")


    <!-- Kategori Sipariş (Bar) -->
    <div class="col-xl-4">

        @await Component.InvokeAsync("_DashboardBarChartComponentPartial")

    </div>

    <!-- Gelir Dağılımı (Pasta) -->
    <div class="col-xl-3">
        <div class="dash-card">
            <div class="dash-card-header">
                <div>
                    <div class="section-title">Gelir Dağılımı</div>
                    <div class="section-sub">Bu ay</div>
                </div>
            </div>
            <div class="dash-card-body">
                <div class="chart-wrap" style="height:180px;">
                    <canvas id="pieChart"></canvas>
                </div>
                <div class="mt-3 d-flex flex-column gap-1" style="font-size:12px;">
                    <div class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:#e6a03c;display:inline-block;"></span> Ana Yemekler — %45</div>
                    <div class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:#3b82f6;display:inline-block;"></span> İçecekler — %25</div>
                    <div class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:#22c55e;display:inline-block;"></span> Tatlılar — %18</div>
                    <div class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:#8b5cf6;display:inline-block;"></span> Başlangıçlar — %12</div>
                </div>
            </div>
        </div>
    </div>

</div>